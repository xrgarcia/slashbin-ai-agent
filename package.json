{
  "name": "slashbin-ai-agent",
  "version": "0.1.0",
  "description": "Open-source daemon that watches GitHub repos for approved issues and implements them using Claude Agent SDK",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "slashbin-ai-agent": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node agent-manager.mjs start",
    "stop": "node agent-manager.mjs stop",
    "restart": "node agent-manager.mjs restart",
    "status": "node agent-manager.mjs status",
    "logs": "node agent-manager.mjs logs",
    "start:fg": "node dist/cli.js",
    "once": "node dist/cli.js --once",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.73",
    "@octokit/rest": "^21.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
